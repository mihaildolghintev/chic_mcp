# Template for .envrc (which is gitignored — it holds RAW values).
# Only needed for deploying from the laptop; CI takes the same values
# from GitHub Actions secrets. Copy and fill in:
#
#   cp .envrc.example .envrc
#
# KAMAL_REGISTRY_PASSWORD  — GitHub PAT (classic) with read:packages + write:packages
# TELEGRAM_BOT_TOKEN       — from @BotFather
# TELEGRAM_WEBHOOK_SECRET  — `openssl rand -hex 32`, generate once and keep
# ALLOWED_USER_IDS         — comma-separated Telegram user ids (ask @userinfobot)
# MOYSKLAD_TOKEN           — MoySklad access token (Settings -> Users -> Access tokens)

export KAMAL_REGISTRY_PASSWORD=ghp_...
export TELEGRAM_BOT_TOKEN=123456:AA...
export TELEGRAM_WEBHOOK_SECRET=
export ALLOWED_USER_IDS=
export MOYSKLAD_TOKEN=
