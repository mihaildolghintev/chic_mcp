# Kamal reads secrets from the environment — this file holds no values,
# so it IS committed (CI needs it in the checkout).
#
# Where the environment comes from:
#   - CI: GitHub Actions secrets (.github/workflows/deploy.yml)
#   - laptop: .envrc (gitignored; template with docs: .envrc.example)

KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD
TELEGRAM_BOT_TOKEN=$TELEGRAM_BOT_TOKEN
TELEGRAM_WEBHOOK_SECRET=$TELEGRAM_WEBHOOK_SECRET
ALLOWED_USER_IDS=$ALLOWED_USER_IDS
MOYSKLAD_TOKEN=$MOYSKLAD_TOKEN
