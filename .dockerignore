# Keep the build context small. pyproject.toml + uv.lock are bind-mounted in
# the deps/dev stages, so they must NOT be ignored.
.git
.github
.venv
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
.env
*.db
*.db-wal
*.db-shm
data/
tests/
docs/
*.md

# Go leftovers — not part of the Python image (removed at cutover)
cmd/
internal/
scripts/
*.go
go.mod
go.sum
.golangci.yml
