# MoySklad access token (Settings -> Users -> Access tokens).
MOYSKLAD_TOKEN=

# Static Bearer token that simple clients (Antigravity, Cursor) send in the
# Authorization header. Generate a long random value, e.g. `openssl rand -hex 32`.
MCP_BEARER_TOKEN=

# Public HTTPS base URL. Used to advertise OAuth discovery metadata to Claude.
PUBLIC_BASE_URL=https://mcp.chic.md

# Single-user login password for the Claude OAuth flow (shown on the /authorize
# form). OAuth is enabled only when PUBLIC_BASE_URL and OAUTH_PASSWORD are both set.
OAUTH_PASSWORD=

# Path to the SQLite response-cache DB. Unset = cache disabled. In Docker this
# points at the mounted volume so the warm cache survives restarts.
CACHE_DB=

# Address the server listens on inside the container.
LISTEN_ADDR=:8080
