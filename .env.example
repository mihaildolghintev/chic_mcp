# --- Telegram bot (bot mode, the default) ---

# Bot token from @BotFather.
TELEGRAM_BOT_TOKEN=

# Webhook secret: appears in the webhook path (/tg/<secret>) and is verified
# against the X-Telegram-Bot-Api-Secret-Token header on every delivery.
# Generate a long random value, e.g. `openssl rand -hex 32`.
TELEGRAM_WEBHOOK_SECRET=

# Comma-separated Telegram user IDs allowed to talk to the bot (ask @userinfobot).
ALLOWED_USER_IDS=

# Public HTTPS base URL the webhook is registered under. In production this is
# the kamal-proxy host; locally, a cloudflared/ngrok tunnel URL.
PUBLIC_BASE_URL=https://bot.chic.md

# Address the server listens on inside the container.
LISTEN_ADDR=:8080

# --- MoySklad (both modes) ---

# MoySklad access token (Settings -> Users -> Access tokens).
MOYSKLAD_TOKEN=

# Path to the SQLite response-cache DB. Unset = cache disabled. In Docker this
# points at the mounted volume so the warm cache survives restarts.
CACHE_DB=

# --- LLM agent (bot mode) ---

# DeepSeek handles text questions (cheap, function calling). At least one of
# the two API keys must be set in bot mode.
DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat

# OpenAI is optional and adds photo understanding (vision). Without it the bot
# asks users to send text instead of photos.
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# Dialog history DB — durable state, unlike the regenerable CACHE_DB. In Docker
# this points at the mounted volume. Defaults to ./app.db for local runs.
APP_DB=

# --- Tracing / observability (optional, bot mode) ---

# Entirely optional: leave this unset and the bot runs with tracing disabled
# (no OpenTelemetry provider is installed, spans become cheap no-ops, nothing is
# sent anywhere). Set it only if you want to see the agent's LLM/tool calls in
# an Arize Phoenix instance.
#
# Base URL of the OTLP/HTTP collector (Phoenix). The exporter appends
# /v1/traces. Example for a Phoenix container on the same Docker network:
#   PHOENIX_COLLECTOR_ENDPOINT=http://phoenix:6006
PHOENIX_COLLECTOR_ENDPOINT=

# Phoenix Cloud only: send the API key as an OTLP header (no code change needed,
# the exporter reads this standard variable). Leave empty for self-hosted.
# OTEL_EXPORTER_OTLP_HEADERS=api_key=<your-phoenix-cloud-key>

# Route traces into a named Phoenix project (keeps prod/dev/local apart).
# Unset = the "default" project. The service name/version/commit are stamped
# automatically from the build; you don't need OTEL_SERVICE_NAME.
# OTEL_RESOURCE_ATTRIBUTES=openinference.project.name=chic-bot

# Environment label attached to every trace (prod, dev, local). Optional.
# APP_ENV=prod
