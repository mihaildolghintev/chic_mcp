# Local dev env. Copy to .env (gitignored). In production these are supplied by
# ../chic-deploy (Kamal + 1Password) — do not commit real values.

# --- Telegram (required) ---
TELEGRAM_BOT_TOKEN=123456:changeme
TELEGRAM_WEBHOOK_SECRET=changeme-openssl-rand-hex-32
ALLOWED_USER_IDS=111111111,222222222
PUBLIC_BASE_URL=https://bot.example.test

# --- MoySklad (required) ---
MOYSKLAD_TOKEN=changeme

# --- LLM (required: DeepSeek text; OpenAI optional for vision) ---
DEEPSEEK_API_KEY=changeme
# OPENAI_API_KEY=            # empty ⇒ photo/vision disabled
# DEEPSEEK_MODEL=deepseek-v4-flash
# OPENAI_MODEL=gpt-5.4-mini

# --- Server / storage (deploy sets these; shown for parity) ---
LISTEN_ADDR=:8080
CACHE_DB=/data/cache.db        # unset ⇒ response cache disabled
APP_DB=/data/app.db
LOG_FORMAT=json                # text | json
# LOG_LEVEL=info

# --- Observability (optional) ---
# PHOENIX_COLLECTOR_ENDPOINT=http://phoenix:6006   # unset ⇒ tracing disabled
# OTEL_EXPORTER_OTLP_HEADERS=api_key=...            # Phoenix Cloud only
# OTEL_RESOURCE_ATTRIBUTES=openinference.project.name=chic-bot
# APP_ENV=local

# --- MCP (optional; unset ⇒ /mcp endpoint not mounted) ---
# MCP_BEARER_TOKEN=at-least-24-characters-long
